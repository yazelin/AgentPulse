{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudePulse",
  "version": "0.1.0",
  "identifier": "com.claudepulse.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx -y serve src -l 1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClaudePulse",
        "width": 300,
        "height": 46,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:1420; style-src 'self' http://localhost:1420 'unsafe-inline'; script-src 'self' http://localhost:1420 'unsafe-inline' 'unsafe-eval'; media-src 'self' blob: data: http://localhost:1420"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true,
      "tooltip": "ClaudePulse"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
